# FinanceMoraiAgent Environment Configuration
# Copy this file to .env and fill in your API keys

# News API (https://newsapi.org/)
NEWS_API_KEY=your_newsapi_key_here

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FinanceMoraiAgent/1.0

# Twitter/X API (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Alpha Vantage (optional, for additional data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# Database (optional, for advanced caching)
DATABASE_URL=sqlite:///storage/finance.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=storage/app.log

# Model Configuration
MOIRAI_MODEL_SIZE=small  # Options: small, base, large
DEVICE=auto  # Options: auto, cpu, cuda, mps

# Cache Configuration
CACHE_TTL_OHLCV=3600  # 1 hour in seconds
CACHE_TTL_NEWS=1800   # 30 minutes
CACHE_TTL_SENTIMENT=7200  # 2 hours
CACHE_TTL_REGIME=3600  # 1 hour

# Feature Flags
ENABLE_GPU=true
ENABLE_SOCIAL_SCRAPING=false
ENABLE_SEC_FILINGS=true
ENABLE_SEBI_FILINGS=true
